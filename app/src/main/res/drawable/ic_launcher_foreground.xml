<?xml version="1.0" encoding="utf-8"?>
<!--
  BatteryGuard — Icono profesional
  Concepto: Batería vertical clásica de alta calidad con rayo de energía.
  Sin texto. Legible desde 48×48 hasta 512×512.
  Fondo configurado en ic_launcher_background.xml (#0B1E0D — verde muy oscuro)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Cuerpo exterior de la batería ────────────────────────────────────
         Forma blanco-suave, bordes redondeados r=7. Proporciones reales de batería.
    -->
    <path
        android:fillColor="#ECF7ED"
        android:pathData="
          M37,27
          Q37,20 44,20
          L64,20
          Q71,20 71,27
          L71,85
          Q71,92 64,92
          L44,92
          Q37,92 37,85
          Z" />

    <!-- ── Terminal superior (el bump de la batería) ─────────────────────── -->
    <path
        android:fillColor="#C8E6C9"
        android:pathData="
          M47,15
          L61,15
          Q65,15 65,19
          L65,23
          L43,23
          L43,19
          Q43,15 47,15
          Z" />

    <!-- ── Cavidad interior oscura ────────────────────────────────────────── -->
    <path
        android:fillColor="#071408"
        android:pathData="
          M41,29
          Q41,27 43,27
          L65,27
          Q67,27 67,29
          L67,83
          Q67,85 65,85
          L43,85
          Q41,85 41,83
          Z" />

    <!-- ── Nivel de carga ≈60% (desde abajo) ─────────────────────────────── -->
    <path
        android:fillColor="#2E7D32"
        android:pathData="
          M41,57
          L67,57
          L67,83
          Q67,85 65,85
          L43,85
          Q41,85 41,83
          Z" />

    <!-- ── Tono más brillante en la franja superior del nivel ─────────────── -->
    <path
        android:fillColor="#43A047"
        android:fillAlpha="0.55"
        android:pathData="M41,57 L67,57 L67,63 L41,63 Z" />

    <!-- ── Rayo de energía — el elemento focal del icono ─────────────────────
         Bold, limpio, centrado. Blanco puro para máximo contraste.
         Flecha tipo zigzag descendente (de arriba-derecha a abajo-izquierda).
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
          M60,31
          L48,56
          L56,56
          L51,79
          L66,52
          L58,52
          Z" />

    <!-- ── Reflejo sutil en el cuerpo de la batería (profundidad) ────────── -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.12"
        android:pathData="
          M37,27
          Q37,20 44,20
          L54,20
          L54,92
          L44,92
          Q37,92 37,85
          Z" />

</vector>
